# Required: a GitHub token used server-side to read PUBLIC contribution data.
# A classic PAT with the `read:user` scope is enough (no repo scope needed).
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# Your deployed site origin (used for absolute OG/share/README URLs).
# Optional on Vercel — auto-detected from VERCEL_* envs. Set for a custom domain.
NEXT_PUBLIC_SITE_URL=https://devwrapped.app

# Optional: Upstash Redis (free tier). Powers TWO features when set:
#  1. durable, multi-instance rate limiting (else an in-memory limiter is used)
#  2. live rarity odds ("only X% of devs are this persona") — hidden until set
# Create a free Upstash Redis DB and paste its REST credentials.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
